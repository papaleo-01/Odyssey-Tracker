# Copy this file to .env and fill in your values
# cp .env.example .env

# Password to access the app (choose something secure)
APP_PASSWORD=changeme

# Secret key for session signing (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_a_random_secret_key

# Port to run the app on
PORT=8000

# Host (use 0.0.0.0 to allow LAN access, 127.0.0.1 for local only)
HOST=0.0.0.0

# Currency symbol
CURRENCY=€

# Application title
APP_TITLE=Odyssey Tracker
